{
  "appId": "com.claimwise.omniscience",
  "appName": "Claimwise Omniscience",
  "webDir": "build",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "Network": {
      "networkStatus": true
    },
    "App": {
      "launchUrl": "index.html"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "scrollEnabled": true
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  }
}
